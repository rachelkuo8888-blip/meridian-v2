# =============================================================================
# Meridian V2 — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# Required for development:
#   - DATABASE_URL (PostgreSQL with pgvector)
#   - REDIS_URL
#
# Required for auth:
#   - NEXT_PUBLIC_SUPABASE_URL
#   - NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# Everything else is optional for local development.
# =============================================================================

# -- Supabase (Auth + Future Cloud DB) ---------------------------------------
# Required for authentication. Get these from your Supabase project dashboard.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -- PostgreSQL (Local Development) ------------------------------------------
# Connection string for local PostgreSQL with pgvector.
# Default connects via Unix socket with trust auth (common for local dev).
# DATABASE_URL=postgresql://postgres@/meridian_memory?host=/var/run/postgresql
#
# Alternative: TCP connection
# DATABASE_URL=postgresql://postgres:password@localhost:5432/meridian_memory

# -- Redis -------------------------------------------------------------------
# Connection string for Redis cache and queue.
REDIS_URL=redis://localhost:6379

# -- App ---------------------------------------------------------------------
# Public URL of the application (used for redirects, OG tags, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- Analytics (Optional) ----------------------------------------------------
# PostHog or custom analytics
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key

# -- LLM Gateway (Optional, for Coach Agent) ---------------------------------
# LLM API for the Coach Agent and content generation.
# LLM_API_KEY=your-llm-api-key
# LLM_API_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# -- Stripe (Optional, for Billing) ------------------------------------------
# Stripe API keys for subscription management.
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# -- Services (Optional, for Local Dev) --------------------------------------
# URLs for the Python microservices running locally.
# CALCULATION_ENGINE_URL=http://localhost:8001
# MEMORY_SERVICE_URL=http://localhost:8002
