    "date-fns": "^4.4.0",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.3.1",
    "tailwind-merge": "^3.6.0",
