{
  "version": 2,
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "regions": ["hkg1"],
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "@next-public-supabase-url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@next-public-supabase-anon-key",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY": "@next-public-stripe-publishable-key",
    "STRIPE_SECRET_KEY": "@stripe-secret-key",
    "STRIPE_PLUS_MONTHLY_PRICE_ID": "@stripe-plus-monthly-price-id",
    "STRIPE_PLUS_YEARLY_PRICE_ID": "@stripe-plus-yearly-price-id",
    "STRIPE_PRO_MONTHLY_PRICE_ID": "@stripe-pro-monthly-price-id",
    "STRIPE_PRO_YEARLY_PRICE_ID": "@stripe-pro-yearly-price-id",
    "NEXT_PUBLIC_APP_URL": "@next-public-app-url"
  }
}
